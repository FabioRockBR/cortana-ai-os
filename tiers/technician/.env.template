# ─────────────────────────────────────────────────────────────────────────────
# CORTANA Technician — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── AI APIs ───────────────────────────────────────────────────────────────────
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google AI Studio (Gemini Embeddings) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# ── Internal Auth ─────────────────────────────────────────────────────────────
# Random secret for split-pdf service auth (generate: openssl rand -hex 32)
CF_AUTH_TOKEN=generate_with_openssl_rand_hex_32

# Postgres password (generate: openssl rand -hex 16)
POSTGRES_PASSWORD=generate_with_openssl_rand_hex_16

# n8n encryption key (generate: openssl rand -hex 24)
N8N_ENCRYPTION_KEY=generate_with_openssl_rand_hex_24

# ── n8n Access ────────────────────────────────────────────────────────────────
# Public URL where n8n is reachable (needed for Telegram webhooks)
# For local testing use ngrok: ngrok http 5678
WEBHOOK_URL=https://your-ngrok-or-domain.ngrok-free.app
N8N_HOST=localhost
N8N_PROTOCOL=http
